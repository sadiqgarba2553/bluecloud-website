{
  "name": "prism-studio",
  "version": "1.0.0",
  "description": "Professional design toolkit for graphic designers",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.prismstudio.app",
    "productName": "Prism Studio",
    "copyright": "Copyright © 2025 Prism Studio",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Prism Studio",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "index.html",
      "main.js",
      "package.json",
      "icon.png",
      "icon.ico"
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1"
  }
}
